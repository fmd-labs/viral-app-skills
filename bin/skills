#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RESTISH_BIN="$ROOT_DIR/.tools/restish/restish"

if [[ ! -x "$RESTISH_BIN" ]]; then
  echo "restish is not installed." >&2
  echo "Run: $ROOT_DIR/scripts/install-restish.sh" >&2
  exit 1
fi

export SKILLS_CLI_ROOT="$ROOT_DIR"
export RESTISH_CONFIG_DIR="$ROOT_DIR/.restish"
export RESTISH_CACHE_DIR="$ROOT_DIR/.restish/cache"
mkdir -p "$RESTISH_CONFIG_DIR" "$RESTISH_CACHE_DIR"

HAS_OUTPUT_FORMAT_FLAG=0
for arg in "$@"; do
  case "$arg" in
    -o|--rsh-output-format|--rsh-output-format=*)
      HAS_OUTPUT_FORMAT_FLAG=1
      break
      ;;
  esac
done

if [[ $HAS_OUTPUT_FORMAT_FLAG -eq 0 && -z "${RSH_OUTPUT_FORMAT:-}" ]]; then
  export RSH_OUTPUT_FORMAT="json"
fi

if [[ -z "${RSH_NO_PAGINATE:-}" ]]; then
  export RSH_NO_PAGINATE="true"
fi

exec "$RESTISH_BIN" skills "$@"
